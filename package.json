{
  "name": "harness-for-todo-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel -r dev",
    "dev:client": "vp run -F client dev",
    "dev:server": "vp run -F server dev",
    "build": "vp build",
    "test": "pnpm run --parallel -r test",
    "test:client": "vp run -F client test",
    "test:server": "vp run -F server test",
    "lint": "vp check && vp lint && pnpm run lint:duplicates",
    "lint:duplicates": "jscpd ./client/src ./server/src",
    "install:all": "vp install",
    "adr:create": "archgate adr create",
    "prepare": "husky"
  },
  "dependencies": {
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "archgate": "^0.9.3",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "oxlint": "^1.55.0",
    "typescript": "~5.9.3",
    "vite-plugin-oxlint": "^2.0.1",
    "vite-plus": "^0.1.11"
  },
  "packageManager": "pnpm@10.32.1"
}
